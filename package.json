{
  "name": "course-ecom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/db-sync.js && tsx scripts/validate-geo.ts --ci && next build",
    "validate:geo": "tsx scripts/validate-geo.ts",
    "test:geo": "tsx scripts/test-geo.ts",
    "db:sync": "node scripts/db-sync.js",
    "db:deploy": "tsx scripts/db-ready.ts && prisma db push --skip-generate && tsx --env-file=.env prisma/seed.ts && tsx --env-file=.env scripts/generate-course-content.ts && tsx --env-file=.env scripts/seed-combos.ts",
    "start": "next start",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "seed": "npm run db:seed",
    "deploy": "bash scripts/deploy.sh",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-state-city": "^3.2.1",
    "framer-motion": "^11.18.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.460.0",
    "next": "^15.0.7",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
