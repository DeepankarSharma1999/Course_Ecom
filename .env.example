DATABASE_URL="postgresql://user:password@localhost:5432/course_ecom?schema=public"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth - generate a random 32+ char string for production
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars-long"

# Social login (learner). Leave empty to disable a provider.
# Google: https://console.cloud.google.com/apis/credentials — OAuth client (Web),
#   authorized redirect URI: <site-url>/api/learner/oauth/google
# LinkedIn: https://developer.linkedin.com/ — app with "Sign In with LinkedIn using OpenID Connect",
#   authorized redirect URI: <site-url>/api/learner/oauth/linkedin
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Default admin user (created by db:seed)
ADMIN_EMAIL="admin@course-ecom.com"
ADMIN_PASSWORD="admin123"

# ============ EMAIL DELIVERY ============
# Provider priority: Resend (if RESEND_API_KEY set) → FormSubmit (if FORMSUBMIT_ENABLED=true) → console fallback.

# Option A: Resend (recommended for production — also delivers learner auto-replies)
RESEND_API_KEY=""
EMAIL_FROM="Course_Ecom <onboarding@resend.dev>"

# Option B: FormSubmit (no API key, free). Set to "true" to enable.
# Recipient email is taken from Site Settings (admin > Site Settings > Email).
# IMPORTANT: First submission to a new address triggers an activation email from FormSubmit —
# click the activation link before subsequent leads will be delivered.
FORMSUBMIT_ENABLED="false"

# Optional override for who gets lead notifications (defaults to Site Settings email).
LEADS_NOTIFICATION_EMAIL=""
