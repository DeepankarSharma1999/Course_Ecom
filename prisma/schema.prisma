// Ulearnsystems training platform - Prisma schema
// Designed to power /[course], /[country]/[course], /[country]/[course]/[city]
// from a single reusable template with admin-managed content.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  tagline   String?
  icon      String?
  image     String?  // banner image URL for the public category page
  order     Int      @default(0)
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Blog articles shown on /resources, managed from admin > Blogs.
model Blog {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  category    String?
  excerpt     String?   @db.Text
  content     String    @db.Text // HTML body
  readMins    Int?
  isPublished Boolean   @default(true)
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Countries and cities drive the /[country] and /[country]/[course]/[city] URLs.
// City.slug is globally unique so a bare /london resolves to exactly one city.
model Country {
  id        String   @id @default(cuid())
  slug      String   @unique
  code      String?
  name      String
  currency  String?
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
}

model Course {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  shortTitle      String?
  subtitle        String?
  summary         String   @db.Text
  description     String   @db.Text
  durationHours   Int?
  durationLabel   String?
  level           String?
  accreditedBy    String?
  basePriceInr    Int?
  basePriceUsd    Int?
  heroImage       String?
  thumbnailImage  String?
  brochureUrl     String?
  meetingUrl      String?  // live-class join link (Zoom/Meet/Teams), shown to enrolled learners
  examIncluded    Boolean  @default(false)
  pduCredits      Int?
  ratingAvg       Float    @default(4.8)
  ratingCount     Int      @default(0)
  isFeatured      Boolean  @default(false)
  isPublished     Boolean  @default(true)
  hiddenSections  String[] @default([]) // course-page section keys to hide (see lib/course-sections.ts)
  pageSections    Json?    // per-course content overrides for instructors/reviews/certificate (see lib/course-section-defaults.ts)

  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])

  keyFeatures     Json?
  learningOutcomes Json?
  whoShouldAttend Json?
  prerequisites   Json?
  curriculum      Json?
  whyChooseUs     Json?

  seoTitle        String?
  seoDescription  String?  @db.Text
  seoKeywords     String?

  faqs            FAQ[]
  schedules       Schedule[]
  pageVariants    CoursePageVariant[]
  trainers        CourseTrainer[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CoursePageVariant {
  id              String   @id @default(cuid())
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  countryCode     String?
  countrySlug     String?
  citySlug        String?
  cityName        String?
  countryName     String?
  currency        String   @default("INR")
  priceLocal      Int?
  heroHeadline    String?
  heroSubheadline String?  @db.Text
  localContext    String?  @db.Text
  seoTitle        String?
  seoDescription  String?  @db.Text
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([courseId, countrySlug, citySlug])
  @@index([countrySlug, citySlug])
}

model Schedule {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  countrySlug String?
  citySlug    String?
  mode        String   // "Live Online" | "Classroom" | "Self-Paced"
  startDate   DateTime
  endDate     DateTime
  timezone    String?
  timeLabel   String?
  priceInr    Int?
  priceUsd    Int?
  discountPct Int?
  seatsLeft   Int?
  isFilling   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([courseId, citySlug])
}

model FAQ {
  id        String   @id @default(cuid())
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  scope     String   @default("course") // "course" | "global"
  question  String   @db.Text
  answer    String   @db.Text
  order     Int      @default(0)
}

model Trainer {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  title       String?
  bio         String?  @db.Text
  photo       String?
  rating      Float?
  reviews     Int?
  expertise   Json?       // string[]
  certifications Json?    // string[]
  experienceYears Int?
  linkedinUrl String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  courses     CourseTrainer[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseTrainer {
  courseId  String
  trainerId String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  @@id([courseId, trainerId])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  quote     String   @db.Text
  rating    Int      @default(5)
  photo     String?
  course    String?
  createdAt DateTime @default(now())
}

model SiteSettings {
  id                 String  @id @default("singleton")
  brandName          String  @default("Ulearnsystems")
  tagline            String  @default("Training & Certifications")
  logoUrl            String?
  faviconUrl         String?

  phone              String  @default("+91 80 4710 6633")
  email              String  @default("info@course-ecom.com")
  whatsappNumber     String?
  address            String? @db.Text

  topBarMessages     Json?     // string[]
  accreditationLogos Json?     // { name, logoUrl?, label? }[]
  socialLinks        Json?     // { linkedin, twitter, facebook, instagram, youtube }

  footerAbout        String? @db.Text
  footerColumns      Json?     // { title, links: { label, href }[] }[]
  copyrightText      String  @default("© Ulearnsystems. All rights reserved.")

  announcementText   String?
  announcementLink   String?
  announcementEnabled Boolean @default(false)

  // Pricing/currency. Prices are stored per course in USD (base). Each currency
  // is computed = usd * perUsd * (1 + premiumPct/100). Admin-editable.
  defaultCurrency    String  @default("USD")
  currencyConfig     Json?     // { code, label, symbol, perUsd, premiumPct, enabled }[]

  defaultSeoTitle    String?
  defaultSeoDescription String? @db.Text

  updatedAt          DateTime @updatedAt
}

model HomePageContent {
  id                  String  @id @default("singleton")

  heroBadgeText       String  @default("Globally accredited certification training")
  heroHeadline        String  @default("Globally Accredited")
  heroHeadlineHighlight String @default("Certification")
  heroHeadlineSuffix  String  @default("Training")
  heroSubheading      String  @db.Text
  heroCtaPrimaryText  String  @default("Explore All Courses")
  heroCtaPrimaryLink  String  @default("/courses")
  heroCtaSecondaryText String @default("Corporate Training")
  heroCtaSecondaryLink String @default("/corporate")
  heroStats           Json?     // { value, label }[]
  heroFormTitle       String  @default("Talk to a Training Advisor")
  heroFormSubtitle    String  @default("Get course details, batch schedules and group discounts.")

  accreditationTitle  String  @default("Accredited Training Partner")

  categoriesBadge     String  @default("Course Catalog")
  categoriesTitle     String  @default("Explore Our Training Categories")
  categoriesSubtitle  String  @db.Text

  coursesBadge        String  @default("Most Popular")
  coursesTitle        String  @default("Bestselling Certification Courses")

  whyUsBadge          String  @default("Why Ulearnsystems")
  whyUsTitle          String  @default("A Training Partner Built for Outcomes, Not Just Certificates")
  whyUsSubtitle       String  @db.Text
  whyUsImage          String?
  whyUsItems          Json?     // { icon, title, body }[]

  testimonialsBadge   String  @default("Learner Stories")
  testimonialsTitle   String  @default("What Our Learners Say")
  testimonialsSubtitle String @default("Real reviews from professionals who advanced their careers with Ulearnsystems.")

  faqBadge            String  @default("FAQ")
  faqTitle            String  @default("Frequently Asked Questions")

  ctaTitle            String  @default("Ready to Advance Your Career?")
  ctaSubtitle         String  @db.Text
  ctaPrimaryText      String  @default("Enquire Now")
  ctaPrimaryLink      String  @default("/enquire")
  ctaSecondaryText    String  @default("Corporate Training")
  ctaSecondaryLink    String  @default("/corporate")

  seoTitle            String?
  seoDescription      String? @db.Text

  // Editable home sections (lists). Null => component falls back to lib/home-defaults.ts.
  partnerLogos        Json?     // { name, label, image }[]
  businessSectors     Json?     // { name, icon }[]
  pedagogyTitle       String  @default("Experience Immersive Learning")
  pedagogySteps       Json?     // { title, text, img }[]
  spotlightArticles   Json?     // { logo, title, img }[]
  accoladesTitle      String  @default("Awards & Recognition")
  accolades           Json?     // { title, org, logo }[]
  reachBadge          String  @default("Global reach")
  reachTitle          String  @default("Training professionals across borders and industries.")
  reachSubtitle       String  @default("Join learners and teams using expert-led programs to build capability across Agile, product, project, technology, and AI domains.") @db.Text
  reachStats          Json?     // { value, label }[]

  // Ordered list of home sections with per-section visibility. Null => default order, all shown.
  sections            Json?     // { key, hidden }[]  (see lib/home-sections.ts)

  updatedAt           DateTime @updatedAt
}

model SimplePage {
  id              String   @id @default(cuid())
  slug            String   @unique     // "corporate" | "enquire" | "about" | ...
  title           String
  heroBadge       String?
  heroHeadline    String?
  heroSubheading  String?  @db.Text
  body            String?  @db.Text     // markdown / HTML
  showLeadForm    Boolean  @default(true)
  leadFormTitle   String?
  leadFormSubtitle String? @db.Text
  ctaText         String?
  ctaLink         String?
  seoTitle        String?
  seoDescription  String?  @db.Text
  isPublished     Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin") // "admin" | "editor"
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Learner {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
  enrollments  Enrollment[]
}

// A learner's enrollment in a course (free enrollments today; paid later).
model Enrollment {
  id          String   @id @default(cuid())
  learnerId   String
  learner     Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  courseSlug  String
  courseTitle String
  priceUsd    Int      @default(0) // 0 = free enrollment
  status      String   @default("pending") // "pending" (awaiting admin confirmation) | "confirmed"
  createdAt   DateTime @default(now())

  @@unique([learnerId, courseSlug])
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  countryCode    String?
  courseSlug     String?
  countrySlug    String?
  citySlug       String?
  message        String?  @db.Text
  source         String?
  consentMarketing Boolean @default(false)
  status         String   @default("new") // "new" | "contacted" | "qualified" | "converted" | "dropped"
  notes          String?  @db.Text
  utm            Json?    // { source, medium, campaign, term, content, referrer, landingPath }
  brochureCourseSlug String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([source])
}

model Page {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  content      String   @db.Text
  requiresAuth Boolean  @default(false)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Structured per-page content overrides for the bespoke marketing pages and nav.
// `content` is a JSON tree whose shape matches the page's defaults in lib/page-defaults.ts.
// Absent row or absent key => the code default is used, so pages render before any edit.
model PageContent {
  slug      String   @id
  content   Json
  updatedAt DateTime @updatedAt
}
